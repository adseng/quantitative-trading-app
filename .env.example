# 复制此文件为 .env.local 或 .env 并填写（可选）

# 币安 USDT 合约 - K线获取为公开接口，无需 API 密钥

BINANCE_BASE_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com

# 若国内无法直连，设置代理（如 Clash/V2Ray 默认端口）
# BINANCE_PROXY=http://127.0.0.1:7890
# 或使用系统代理环境变量：HTTPS_PROXY=http://127.0.0.1:7890

# 请求超时秒数，默认 30（网络慢可适当增大）
# BINANCE_REQUEST_TIMEOUT=60

# 合约交易对
BINANCE_SYMBOL=BTCUSDT

# Coze 智能体（用于 K 线短期走势预测，cmd/cozepredict）
# Token: https://www.coze.com/open/oauth/pats （国内: https://www.coze.cn/open/oauth/pats）
# Bot ID: 在 Coze 平台发布智能体后，从 URL 中获取
COZE_API_TOKEN=
COZE_BOT_ID=
# 国内环境可设置: COZE_API_BASE=https://api.coze.cn
